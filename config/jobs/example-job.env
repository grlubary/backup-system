JOB_NAME="example-job"

# Leave SOURCE_HOST empty to back up the local machine.
SOURCE_HOST="root@example-host"

BACKUP_PATHS=(
"/etc"
"/home"
"/var/www"
)

DEST_ROOT="/backup-repo"

DAILY_KEEP=7
WEEKLY_KEEP=4
MONTHLY_KEEP=12
YEARLY_KEEP=5

RSYNC_SSH="ssh -o BatchMode=yes"
EXCLUDE_FILE="/opt/backup-system/config/excludes/linux-common.txt"

LOG_ROOT="/var/log/backup-system"
STATE_ROOT="/var/lib/backup-state"

# Set to 1 when DEST_ROOT must be a mounted filesystem.
REQUIRE_MOUNT=1

# Basic first-run safety checks.
MIN_SNAPSHOT_SIZE_BYTES=1
MIN_EXPECTED_ENTRIES=1
